# ==== Copy this file to `.env` and fill in the values ====

# --- Claude (Anthropic) ---
# Get a key at https://console.anthropic.com/  ->  API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model for reading receipt images + answering questions (default is fine)
ANTHROPIC_MODEL=claude-opus-4-8

# --- WhatsApp ---
# The EXACT group name as it appears in WhatsApp, OR the group id (ends with @g.us).
# Easiest: leave the name, run once, scan QR, and the bot will print the ids of all
# your groups in the console so you can copy the right @g.us id back here.
WHATSAPP_GROUP_NAME=DADA - Financial Report Group
WHATSAPP_GROUP_ID=

# If true, the bot only READS and logs — it never posts back into the group.
# Set to false once you've verified the parsing is correct.
DRY_RUN=true

# --- Notion (optional — leave blank to skip Notion logging for now) ---
# 1. Create an internal integration: https://www.notion.com/my-integrations
# 2. Share your ledger database with that integration.
# 3. Copy the database id from its URL.
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Currency / locale ---
# Receipts are Indonesian Rupiah. "id-ID" formats 12496000 as 12.496.000
CURRENCY=IDR
LOCALE=id-ID

# --- Storage ---
DATA_DIR=./data

# --- Proxy (only needed if the Anthropic API is geo-blocked from your location) ---
# Node does NOT use the system proxy automatically. If you're in mainland China,
# set this to your local proxy's HTTP port so the bot routes through your VPN.
#   Clash / Clash Verge default:   http://127.0.0.1:7890
#   V2RayN (HTTP) default:         http://127.0.0.1:10809
# Leave BLANK when running on an overseas server (no proxy needed there).
PROXY_URL=
