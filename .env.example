# ==== Copy this file to `.env` and fill in the values ====

# --- Claude (Anthropic) ---
# Get a key at https://console.anthropic.com/  ->  API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model for reading receipt images + answering questions (default is fine)
ANTHROPIC_MODEL=claude-opus-4-8

# --- WhatsApp ---
# The EXACT group name as it appears in WhatsApp, OR the group id (ends with @g.us).
# Easiest: leave the name, run once, scan QR, and the bot will print the ids of all
# your groups in the console so you can copy the right @g.us id back here.
WHATSAPP_GROUP_NAME=DADA - Financial Report Group
WHATSAPP_GROUP_ID=

# If true, the bot only READS and logs — it never posts back into the group.
# Set to false once you've verified the parsing is correct.
DRY_RUN=true

# --- Notion ---
# Internal integration token (workspace owner/admin creates it at
# https://www.notion.com/my-integrations and shares the EXPENSES database with it).
NOTION_API_KEY=
# The "EXPENSES" DATA SOURCE id to write rows into (2025-09-03 multi-source API).
# Find it with: npx tsx src/cli/notion-schema.ts
#   real "EXPENSES"     data source: 27925f1b-255a-80df-9bd0-000b7968e853
#   "EXPENSES (1)" copy data source: cec25f1b-255a-8390-b86b-076832d4f087  (use the test copy first!)
NOTION_DATA_SOURCE_ID=
# 'preview' = log the row but DON'T write to Notion (safe). 'live' = actually create the row.
NOTION_WRITE=preview

# --- Expense submission ---
# 'auto'    = any receipt photo, or any message with a date/amount, is treated as an
#             expense submission (best for a dedicated expense group). No keyword needed.
# 'keyword' = only messages containing TRIGGER_KEYWORD are processed (strict).
TRIGGER_MODE=auto
# Optional keyword accelerator; only REQUIRED in 'keyword' mode.
TRIGGER_KEYWORD=exp

# --- Currency / locale ---
# Receipts are Indonesian Rupiah. "id-ID" formats 12496000 as 12.496.000
CURRENCY=IDR
LOCALE=id-ID

# --- Storage ---
DATA_DIR=./data

# --- Proxy (only needed if the Anthropic API is geo-blocked from your location) ---
# Node does NOT use the system proxy automatically. If you're in mainland China,
# set this to your local proxy's HTTP port so the bot routes through your VPN.
#   Clash / Clash Verge default:   http://127.0.0.1:7890
#   V2RayN (HTTP) default:         http://127.0.0.1:10809
# Leave BLANK when running on an overseas server (no proxy needed there).
PROXY_URL=
